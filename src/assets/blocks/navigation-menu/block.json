{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "croco-blocks/navigation-menu",
	"version": "1.0.0",
	"title": "Navigation Menu",
	"category": "croco-blocks",
	"icon": "menu",
	"description": "A navigation block with menu selection and styling options.",
	"textdomain": "croco-blocks",
	"attributes": {
		"menuId": {
			"type": "number",
			"default": 0
		},
		"textColor": {
			"type": "string",
			"default": ""
		},
		"backgroundColor": {
			"type": "string",
			"default": ""
		},
		"customTextColor": {
			"type": "string",
			"default": ""
		},
		"customBackgroundColor": {
			"type": "string",
			"default": ""
		},
		"fontSize": {
			"type": "string",
			"default": ""
		},
		"customFontSize": {
			"type": "string",
			"default": ""
		},
		"itemSpacing": {
			"type": "string",
			"default": "20px"
		},
		"orientation": {
			"type": "string",
			"default": "horizontal",
			"enum": [ "horizontal", "vertical" ]
		},
		"alignmentDesktop": {
			"type": "string",
			"default": "left"
		},
		"alignmentTablet": {
			"type": "string",
			"default": ""
		},
		"alignmentMobile": {
			"type": "string",
			"default": ""
		},
		"submenuTextColor": {
			"type": "string",
			"default": ""
		},
		"submenuTextHoverColor": {
			"type": "string",
			"default": ""
		},
		"submenuAlignment": {
			"type": "string",
			"default": "center"
		},
		"submenuTextAlignment": {
			"type": "string",
			"default": "left"
		},
		"submenuOffsetTop": {
			"type": "string",
			"default": "0px"
		},
		"submenuHoverBackgroundColor": {
			"type": "string",
			"default": ""
		},
		"submenuItemPadding": {
			"type": "string",
			"default": "0.4rem 1rem"
		},
		"mobileMenuTextColor": {
			"type": "string",
			"default": ""
		},
		"mobileMenuHoverTextColor": {
			"type": "string",
			"default": ""
		},
		"mobileSubmenuTextColor": {
			"type": "string",
			"default": ""
		},
		"mobileSubmenuHoverTextColor": {
			"type": "string",
			"default": ""
		},
		"menuItemPadding": {
			"type": "string",
			"default": "0px"
		},
		"menuItemPaddingVertical": {
			"type": "string",
			"default": "0px"
		},
		"menuItemTextColor": {
			"type": "string",
			"default": ""
		},
		"menuItemTextHoverColor": {
			"type": "string",
			"default": ""
		},
		"menuItemFontSize": {
			"type": "string",
			"default": ""
		},
		"menuItemFontSizeDesktop": {
			"type": "number",
			"default": 0
		},
		"menuItemFontSizeTablet": {
			"type": "number",
			"default": 0
		},
		"menuItemFontSizeMobile": {
			"type": "number",
			"default": 0
		},
		"menuItemFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"menuItemFontWeight": {
			"type": "string",
			"default": ""
		},
		"menuItemLineHeight": {
			"type": "number",
			"default": 0
		},
		"menuItemLineHeightSet": {
			"type": "boolean",
			"default": false
		},
		"menuItemLineHeightUnit": {
			"type": "string",
			"default": ""
		},
		"menuItemLetterSpacing": {
			"type": "string",
			"default": ""
		},
		"menuItemLetterSpacingValue": {
			"type": "number",
			"default": 0
		},
		"menuItemLetterSpacingSet": {
			"type": "boolean",
			"default": false
		},
		"menuItemLetterSpacingUnit": {
			"type": "string",
			"default": ""
		},
		"enableToggle": {
			"type": "boolean",
			"default": false
		},
		"toggleBreakpoint": {
			"type": "string",
			"enum": [ "tablet", "mobile" ],
			"default": "mobile"
		},
		"toggleIconColor": {
			"type": "string",
			"default": ""
		},
		"toggleIconSize": {
			"type": "string",
			"default": "18px"
		},
		"toggleIconPadding": {
			"type": "string",
			"default": "0px"
		},
		"offcanvasWidth": {
			"type": "string",
			"default": "70vw"
		},
		"offcanvasBackgroundColor": {
			"type": "string",
			"default": ""
		},
		"offcanvasMenuItemPaddingHorizontal": {
			"type": "string",
			"default": "0px"
		},
		"offcanvasMenuItemPaddingVertical": {
			"type": "string",
			"default": "0px"
		},
		"showDropdownIndicator": {
			"type": "boolean",
			"default": false
		},
		"dropdownIndicatorGap": {
			"type": "string",
			"default": "8px"
		},
		"dropdownIndicatorSize": {
			"type": "string",
			"default": "12px"
		},
		"style": {
			"type": "object"
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": false,
		"spacing": false,
		"typography": false,
		"className": true,
		"customClassName": false,
		"anchor": true
	},
	"editorScript": "file:./index.js",
	"editorStyle": [
		"file:../../editor-shared/index.css",
		"file:./index.css"
	],
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"render": "file:./render.php"
}
