{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "croco-blocks/hero-slider",
	"version": "1.0.0",
	"title": "Hero Slider",
	"category": "croco-blocks",
	"icon": "images-alt2",
	"description": "A hero slider with background images, heading, text, and a call-to-action button for each slide.",
	"textdomain": "croco-blocks",
	"attributes": {
		"slides": {
			"type": "array",
			"default": []
		},
		"showArrows": {
			"type": "boolean",
			"default": true
		},
		"showDots": {
			"type": "boolean",
			"default": true
		},
		"autoplay": {
			"type": "boolean",
			"default": true
		},
		"autoplaySpeed": {
			"type": "number",
			"default": 5000
		},
		"loop": {
			"type": "boolean",
			"default": true
		},
		"pauseOnHover": {
			"type": "boolean",
			"default": true
		},
		"heightMode": {
			"type": "string",
			"default": "vh",
			"enum": [ "auto", "fixed", "vh" ]
		},
		"heightDesktop": {
			"type": "string",
			"default": "80vh"
		},
		"heightTablet": {
			"type": "string",
			"default": "60vh"
		},
		"heightMobile": {
			"type": "string",
			"default": "60vh"
		},
		"overlayColor": {
			"type": "string",
			"default": ""
		},
		"overlayGradient": {
			"type": "string",
			"default": ""
		},
		"overlayOpacity": {
			"type": "number",
			"default": 50
		},
		"contentAlign": {
			"type": "string",
			"default": "left"
		},
		"headingColor": {
			"type": "string",
			"default": ""
		},
		"textColor": {
			"type": "string",
			"default": ""
		},
		"headingFontSize": {
			"type": "number",
			"default": 0
		},
		"textFontSize": {
			"type": "number",
			"default": 0
		},
		"headingFontSizeDesktop": {
			"type": "number",
			"default": 0
		},
		"headingFontSizeTablet": {
			"type": "number",
			"default": 0
		},
		"headingFontSizeMobile": {
			"type": "number",
			"default": 0
		},
		"headingFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"textFontSizeDesktop": {
			"type": "number",
			"default": 0
		},
		"textFontSizeTablet": {
			"type": "number",
			"default": 0
		},
		"textFontSizeMobile": {
			"type": "number",
			"default": 0
		},
		"textFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"headingLineHeight": {
			"type": "number",
			"default": 0
		},
		"textLineHeight": {
			"type": "number",
			"default": 0
		},
		"headingMarginBottom": {
			"type": "number",
			"default": 0
		},
		"textMarginBottom": {
			"type": "number",
			"default": 0
		},
		"headingMarginBottomDesktop": {
			"type": "number",
			"default": 0
		},
		"headingMarginBottomTablet": {
			"type": "number",
			"default": 0
		},
		"headingMarginBottomMobile": {
			"type": "number",
			"default": 0
		},
		"headingMarginBottomUnit": {
			"type": "string",
			"default": "px"
		},
		"textMarginBottomDesktop": {
			"type": "number",
			"default": 0
		},
		"textMarginBottomTablet": {
			"type": "number",
			"default": 0
		},
		"textMarginBottomMobile": {
			"type": "number",
			"default": 0
		},
		"textMarginBottomUnit": {
			"type": "string",
			"default": "px"
		},
		"contentMaxWidth": {
			"type": "number",
			"default": 0
		},
		"contentPaddingTopDesktop": {
			"type": "number",
			"default": 0
		},
		"contentPaddingTopTablet": {
			"type": "number",
			"default": 0
		},
		"contentPaddingTopMobile": {
			"type": "number",
			"default": 0
		},
		"contentPaddingTopUnit": {
			"type": "string",
			"default": "px"
		},
		"buttonAlign": {
			"type": "string",
			"default": "left"
		},
		"buttonPaddingY": {
			"type": "number",
			"default": 0
		},
		"buttonPaddingX": {
			"type": "number",
			"default": 0
		},
		"buttonMarginTop": {
			"type": "number",
			"default": 0
		},
		"buttonBorderRadius": {
			"type": "number",
			"default": 0
		},
		"buttonBorderWidth": {
			"type": "number",
			"default": 0
		},
		"buttonBgColor": {
			"type": "string",
			"default": ""
		},
		"buttonBgColorHover": {
			"type": "string",
			"default": ""
		},
		"buttonTextColor": {
			"type": "string",
			"default": ""
		},
		"buttonTextColorHover": {
			"type": "string",
			"default": ""
		},
		"buttonBorderColor": {
			"type": "string",
			"default": ""
		},
		"buttonIconId": {
			"type": "number",
			"default": 0
		},
		"buttonIconUrl": {
			"type": "string",
			"default": ""
		},
		"buttonIconAlt": {
			"type": "string",
			"default": ""
		},
		"buttonShowText": {
			"type": "boolean",
			"default": true
		},
		"buttonIconSizeDesktop": {
			"type": "number",
			"default": 0
		},
		"buttonIconSizeTablet": {
			"type": "number",
			"default": 0
		},
		"buttonIconSizeMobile": {
			"type": "number",
			"default": 0
		},
		"buttonStyle": {
			"type": "string",
			"default": "filled"
		},
		"cbPaddingTop": {
			"type": "string",
			"default": ""
		},
		"cbPaddingRight": {
			"type": "string",
			"default": ""
		},
		"cbPaddingBottom": {
			"type": "string",
			"default": ""
		},
		"cbPaddingLeft": {
			"type": "string",
			"default": ""
		},
		"cbMarginTop": {
			"type": "string",
			"default": ""
		},
		"cbMarginBottom": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"align": false,
		"color": false,
		"spacing": false,
		"typography": false,
		"className": false,
		"customClassName": false,
		"anchor": false
	},
	"editorScript": "file:./index.js",
	"editorStyle": [
		"file:../../editor-shared/index.css",
		"file:./index.css"
	],
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"render": "file:./render.php"
}
